# ClawBrain environment variable template
# Copy as .env and fill in actual values, .env will not be committed to Git

# ── Memory System ────────────────────────────────────────────────────────────
CLAWBRAIN_DB_DIR=/app/data
CLAWBRAIN_MAX_CONTEXT_CHARS=2000
CLAWBRAIN_TRACE_TTL_DAYS=30

# ── Router Extension (Optional) ────────────────────────────────────────────────
# Inject extra Provider (JSON string)
# CLAWBRAIN_EXTRA_PROVIDERS={"myprovider": {"base_url": "http://...", "protocol": "openai"}}

# Inject local model whitelist (JSON string)
# CLAWBRAIN_LOCAL_MODELS=["my-local-model"]

# ── Upstream API Keys (Passed through to the corresponding Provider) ──────────
# The Authorization in the request header from the client will be forwarded by the gateway as is; no configuration is needed here.
# If you need to preset keys for specific backends, you can add them here and read them in the ProviderRegistry.
