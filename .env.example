# ClawBrain 环境变量模板
# 复制为 .env 并填入真实值，.env 不会进入 Git

# ── 记忆系统 ────────────────────────────────────────────────────────────────
CLAWBRAIN_DB_DIR=/app/data
CLAWBRAIN_MAX_CONTEXT_CHARS=2000
CLAWBRAIN_TRACE_TTL_DAYS=30

# ── 路由扩展（可选）────────────────────────────────────────────────────────
# 注入额外 Provider（JSON 字符串）
# CLAWBRAIN_EXTRA_PROVIDERS={"myprovider": {"base_url": "http://...", "protocol": "openai"}}

# 注入本地模型白名单（JSON 字符串）
# CLAWBRAIN_LOCAL_MODELS=["my-local-model"]

# ── 上游 API 密钥（透传给对应 Provider）────────────────────────────────────
# 客户端在请求头中携带的 Authorization 会被网关原样转发，无需在此配置。
# 如需为特定后端预设密钥，可在此添加并在 ProviderRegistry 中读取。
