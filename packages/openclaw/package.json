  },
  "keywords": ["openclaw", "clawbrain", "context-engine", "memory", "llm"],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.4.5",
    "vitest": "^1.6.0",
    "@types/node": "^20.14.0"
  }
