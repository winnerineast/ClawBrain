{
  "name": "@clawbrain/openclaw",
  "version": "1.0.0",
  "description": "ClawBrain Context Engine plugin for OpenClaw — tri-layer neural memory via localhost HTTP",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
