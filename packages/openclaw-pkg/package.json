{
  "name": "clawbrain",
  "version": "1.0.0",
  "description": "ClawBrain Context Engine plugin for OpenClaw",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "openclaw": {
    "id": "clawbrain",
    "type": "context-engine",
    "extensions": [
      "dist/index.js"
    ],
    "permissions": {
      "env": [
        "CLAWBRAIN_URL",
        "CLAWBRAIN_TIMEOUT_MS"
      ],
      "network": {
        "hosts": [
          "127.0.0.1",
          "localhost"
        ]
      }
    }
  }
}
